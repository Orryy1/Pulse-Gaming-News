.env
.env.*
!.env.example
node_modules/
output/
test/output/
dist/
daily_news.json
pending_news.json
image_queue.json
video_queue.json
engagement_first_hour_log.json

# --- Secret-bearing files (see docs/security-hygiene.md) ---
# Local OAuth tokens, API tokens, deploy scripts. If any of these end
# up committed, the corresponding secret MUST be rotated immediately.
tokens/
.youtube_token*
.github_token*
.railway_token*
railway_deploy.bat
railway_deploy.sh
railway_deploy.ps1
# Windows-escaped filenames generated when a Windows path is accidentally
# git-added (e.g. C:/Users/…/railway_deploy.bat becomes C + fullwidth-colon
# + UsersMORRrailway_deploy.bat). Catch-all guard so this cannot recur.
CUsersMORR*
C*UsersMORR*
*railway_deploy.bat

# --- Local SQLite + lock files ---
data/
!data/.keep

# --- Local diagnostics / logs ---
*.log
tts_server/diag/
tts_server/server.log
tts_server/server.log.*
tts_server/faulthandler.*.log
tts_server/boot_state.json
tts_server/venv/
tts_lab/
tts_lab/chatterbox_venv/
tts_lab/__pycache__/

# --- Local test assets that are never part of the app ---
test_videos/
test_imagen.jpg
engagement_stats.json

# --- Per-story HyperFrames experiment outputs (committed templates only) ---
# Templates that ship with the repo: experiments/hf-thumbnail/, hf-quote/,
# hf-takeaway/, hf-timeline/. Per-story instances built at runtime by
# hf-thumbnail-builder.js et al. land in experiments/hf-thumbnail-<id>/
# and must NOT be committed.
experiments/hf-thumbnail-*/
experiments/hf-timeline-*/
experiments/hf-quote-*/
experiments/hf-takeaway-*/
experiments/hf-context-*/
experiments/hf-outro-*/
experiments/hf-source-*/
experiments/hf-quote/assets/backdrop.jpg
experiments/hf-takeaway/assets/backdrop.jpg

# --- Local generated branding/audio packs ---
# Canonical shipped branding assets use stable names such as
# branding/profile_picture.png and remain tracked. Numbered exports
# are local design-tool variants and should be reviewed explicitly
# before replacing the canonical assets.
branding/[0-9]*.png
branding/[0-9]*.gif
branding/[0-9]*.mp4
branding/Archived/
branding/Brand Identity for Image Generation.md
audio/flac/
audio/broadcast_vol1_cover.jpg
audio/epidemic/**/*.aac
audio/epidemic/**/*.flac
audio/epidemic/**/*.m4a
audio/epidemic/**/*.mp3
audio/epidemic/**/*.wav

# --- Local scratch/prototype entrypoints and story dumps ---
# These root-level files are legacy one-off experiments or local exports.
# Canonical app code lives under tracked lib/, tools/ and uploader modules.
backgrounds.js
imagen.js
news-post-vol.json
news.json
overlays.js
scraper.js
subtitles.js
youtube.js

# --- Claude Code / editor local state ---
.claude/settings.local.json
.claude/launch.json
