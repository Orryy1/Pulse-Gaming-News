{
  "name": "pulse-gaming",
  "private": true,
  "version": "1.0.0",
  "description": "Automated gaming news pipeline with React dashboard",
  "scripts": {
    "start": "node scripts/ensure-ffmpeg.js && node server.js",
    "hunt": "node run.js hunt",
    "produce": "node run.js produce",
    "schedule": "node run.js schedule",
    "dev": "concurrently \"node server.js\" \"npx vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test \"tests/**/*.test.js\"",
    "quality:test": "node tools/quality-test.js",
    "quality:render": "node tools/quality-render.js",
    "studio:v1:cards": "node tools/render-hyperframes-cards.js",
    "studio:v1": "node tools/render-hyperframes-cards.js && node tools/studio-v1-render.js",
    "studio:v2:qa": "node tools/studio-v2-forensic-qa.js",
    "studio:v2:qa:compare": "node tools/studio-v2-forensic-compare.js",
    "studio:v2:gauntlet": "node tools/studio-v2-gauntlet.js",
    "studio:v21": "node tools/studio-v21-render.js",
    "studio:v21:gate": "node tools/studio-v21-gate.js",
    "studio:v2:channel-readiness": "node tools/studio-v2-channel-readiness.js",
    "studio:v2:dossier": "node tools/studio-v2-qa-dossier.js",
