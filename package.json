{
  "name": "pulse-gaming",
  "private": true,
  "version": "1.0.0",
  "description": "Automated gaming news pipeline with React dashboard",
  "scripts": {
    "start": "node scripts/ensure-ffmpeg.js && node server.js",
    "hunt": "node run.js hunt",
    "produce": "node run.js produce",
    "schedule": "node run.js schedule",
    "dev": "concurrently \"node server.js\" \"npx vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test \"tests/**/*.test.js\"",
    "quality:test": "node tools/quality-test.js",
    "quality:render": "node tools/quality-render.js",
    "studio:v1:cards": "node tools/render-hyperframes-cards.js",
    "studio:v1": "node tools/render-hyperframes-cards.js && node tools/studio-v1-render.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@sentry/node": "^8.0.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^11.10.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "discord.js": "^14.16.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.344.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2"
  }
}
