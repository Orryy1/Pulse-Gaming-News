    "@anthropic-ai/sdk": "^0.91.1",
    "@sentry/node": "^8.0.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^11.10.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "discord.js": "^14.16.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "googleapis": "^171.4.0",
    "hyperframes": "^0.4.30",
    "lucide-react": "^0.344.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.59.1",
