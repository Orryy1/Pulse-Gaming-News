# .env.worker — loaded by scripts/task-scheduler/pulse-worker.ps1 when present.
# Copy to project root as `.env.worker` and edit. Do NOT commit the real file.

# Cloud endpoint the worker polls. Railway public URL in production.
WORKER_CLOUD_URL=https://pulse-gaming-news.up.railway.app

# Shared secret. Falls back to API_TOKEN if unset server-side; on the
# worker side set whichever of the two the cloud actually honours.
WORKER_TOKEN=change-me

# Stable worker id. Lets the dashboard show a friendly name and lets the
# scoring dashboard attribute GPU minutes per host.
WORKER_ID=local-gaming-rig

# Restrict to GPU-required kinds. Without this the local box would
# compete with the cloud runner for CPU-only jobs.
WORKER_GPU=1
WORKER_KINDS=image,audio,assemble,tts,music

# Power policy.
WORKER_MIN_IDLE_SEC=600             # 10 minutes of user inactivity required
WORKER_PROTECTED_APPS=obs64.exe,Cyberpunk2077.exe,ModernWarfare.exe
WORKER_BATTERY_OK=0                 # pause on battery (laptop-safe default)
# WORKER_IGNORE_POWER=1             # uncomment to disable every gate (testing)
# WORKER_WINDOW_START=01:00         # UTC; only claim between these times
# WORKER_WINDOW_END=07:00
