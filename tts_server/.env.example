# Local TTS server configuration

# Reference voice for cloning (6-30s WAV/MP3 of YOUR OWN voice or one you
# have rights to). Leave blank to use VoxCPM 2's default voice (varies per
# session, fine for testing).
REF_VOICE_PATH=

# Global speed multiplier applied via pitch-preserving phase vocoder. The
# pipeline's per-segment speaking_rate is multiplied on top of this.
#   2.6  - Pulse Gaming target (~140 WPM)
#   1.4  - Sleepy Stories target (~70 WPM)
#   1.0  - VoxCPM native (~50 WPM, very slow)
BASE_SPEED=2.6

# CUDA device
DEVICE=cuda

# Server bind
HOST=127.0.0.1
PORT=8765

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
